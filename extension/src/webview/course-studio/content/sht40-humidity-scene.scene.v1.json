          "binding": {
            "path": "sht40.rh",
            "map": [{ "op": "scale", "inMin": 0, "inMax": 100, "outMin": 0, "outMax": 0.9 }],
            "fallback": 0
          }
        },
        "z": {
          "base": 0.6,
          "mode": "add",
          "binding": {
            "path": "sht40.rh",
            "map": [{ "op": "scale", "inMin": 0, "inMax": 100, "outMin": 0, "outMax": 0.9 }],
            "fallback": 0
          }
