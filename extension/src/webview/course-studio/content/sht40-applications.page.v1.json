{
  "version": 1,
  "id": "sht40-applications",
  "title": "SHT40 — Applications & dashboards",
  "meta": {
    "telemetryPreference": "auto",
    "staleMs": 2000,
    "defaultLinkHealth": "freeze-gray"
  },
  "grid": {
    "columns": 12,
    "rowHeightPx": 48,
    "gapPx": 12,
    "paddingPx": 32
  },
  "blocks": [
    {
      "id": "heading-apps",
      "kind": "heading",
      "placement": { "column": 1, "row": 1, "columnSpan": 12, "rowSpan": 2 },
      "eyebrow": "SHT40 · Applications",
      "title": "From RH/T physics to operator dashboards",
      "subtitle": "Where environmental sensing matters in practice, and how Sensor Studio maps live SHT40 streams to Dashboard widgets.",
      "icon": "LayoutDashboard"
    },
    {
      "id": "callout-studio",
      "kind": "callout-tip",
      "placement": { "column": 1, "row": 3, "columnSpan": 12, "rowSpan": 2 },
      "title": "Node-based tooling",
      "body": "Open Sensor Studio to wire SHT40 humidity and temperature taps into gauges, plots, and comfort classifiers on the Dashboard.",
      "icon": "Lightbulb"
    },
    {
      "id": "md-apps",
      "kind": "markdown",
      "placement": { "column": 1, "row": 5, "columnSpan": 7, "rowSpan": 5 },
      "src": "sht40-applications.theory.md"
    },
    {
      "id": "dash-apps-temp",
      "kind": "dashboard-widget",
      "placement": { "column": 8, "row": 5, "columnSpan": 5, "rowSpan": 2 },
      "title": "Temperature",
      "widgetKind": "text",
      "style": {
        "label": "Temperature",
        "unit": "°C",
        "decimals": 1,
        "showStatusBar": true
      },
      "binding": {
        "path": "sht40.temp",
        "fallback": 0,
        "unit": "°C",
        "format": "0.0f"
      }
    },
    {
      "id": "dash-apps-rh",
      "kind": "dashboard-widget",
      "placement": { "column": 8, "row": 7, "columnSpan": 5, "rowSpan": 2 },
      "title": "Humidity",
      "widgetKind": "text",
      "style": {
        "label": "Humidity",
        "unit": "%RH",
        "decimals": 1,
        "showStatusBar": true
      },
      "binding": {
        "path": "sht40.rh",
        "fallback": 0,
        "unit": "%RH",
        "format": "0.0f"
      }
    },
    {
      "id": "card-apps",
      "kind": "card",
      "placement": { "column": 8, "row": 9, "columnSpan": 5, "rowSpan": 2 },
      "title": "Studio checklist",
      "body": "Add SHT40 input or tap nodes.\nWire humidity + temperature outputs.\nSet LED thresholds for comfort bands.\nMatch publish interval to slow drift."
    }
  ]
}
