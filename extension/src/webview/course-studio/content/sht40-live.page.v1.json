{
  "version": 1,
  "id": "sht40-live",
  "title": "SHT40 — Live visualization",
  "meta": {
    "telemetryPreference": "auto",
    "staleMs": 2000,
    "defaultLinkHealth": "freeze-gray"
  },
  "grid": {
    "columns": 12,
    "rowHeightPx": 48,
    "gapPx": 12,
    "paddingPx": 32
  },
  "blocks": [
    {
      "id": "heading-live",
      "kind": "heading",
      "placement": { "column": 1, "row": 1, "columnSpan": 12, "rowSpan": 2 },
      "eyebrow": "SHT40 · Live",
      "title": "Humidity sphere, comfort diagram, and deck cards",
      "subtitle": "3D RH sphere, comfort-band diagram, and humidity cards from one SHT40 stream."
    },
    {
      "id": "callout-tip",
      "kind": "callout-tip",
      "placement": { "column": 1, "row": 3, "columnSpan": 12, "rowSpan": 2 },
      "title": "Enable SHT40",
      "body": "If cards stay gray, open sensor settings and confirm SHT40 is enabled with TEMP and HUM published.",
      "icon": "Lightbulb"
    },
    {
      "id": "md-live",
      "kind": "markdown",
      "placement": { "column": 1, "row": 5, "columnSpan": 5, "rowSpan": 5 },
      "src": "sht40-live.theory.md"
    },
    {
      "id": "card-sht40-humidity",
      "kind": "sensor-telemetry-card",
      "placement": { "column": 6, "row": 5, "columnSpan": 3, "rowSpan": 5 },
      "preset": "sht40Humidity"
    },
    {
      "id": "card-sht40-temperature",
      "kind": "sensor-telemetry-card",
      "placement": { "column": 9, "row": 5, "columnSpan": 4, "rowSpan": 5 },
      "preset": "sht40Temperature"
    },
    {
      "id": "scene-humidity",
      "kind": "scene-3d",
      "placement": { "column": 1, "row": 10, "columnSpan": 12, "rowSpan": 4 },
      "documentId": "sht40-humidity-scene",
      "caption": "RH-driven sphere scale (3D scene)"
    },
    {
      "id": "comfort-diagram",
      "kind": "diagram-2d",
      "placement": { "column": 1, "row": 14, "columnSpan": 12, "rowSpan": 4 },
      "diagramId": "sht40-comfort-gauge",
      "caption": "Comfort band & RH marker"
    }
  ]
}
