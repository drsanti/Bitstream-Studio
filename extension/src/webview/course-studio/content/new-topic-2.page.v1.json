{
  "version": 1,
  "id": "new-topic-2",
  "title": "New topic",
  "grid": {
    "columns": 12,
    "rowHeightPx": 48,
    "gapPx": 12,
    "paddingPx": 32
  },
  "blocks": [
    {
      "id": "html-page-1",
      "kind": "html-page",
      "placement": {
        "column": 1,
        "row": 1,
        "columnSpan": 12,
        "rowSpan": 8
      },
      "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Modern EV Car Dashboard</title>\n  <style>\n    :root {\n      --bg: #070b12;\n      --panel: rgba(18, 27, 43, 0.72);\n      --panel-2: rgba(11, 18, 30, 0.92);\n      --line: rgba(124, 242, 255, 0.22);\n      --text: #eaf7ff;\n      --muted: #8ca4b8;\n      --cyan: #42e8ff;\n      --blue: #5477ff;\n      --green: #54ff9d;\n      --yellow: #ffd166;\n      --red: #ff5f7e;\n      --glass: blur(18px) saturate(150%);\n    }\n\n    * { box-sizing: border-box; }\n\n    body {\n      margin: 0;\n      min-height: 100vh;\n      color: var(--text);\n      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n      background:\n        radial-gradient(circle at 15% 10%, rgba(66, 232, 255, 0.18), transparent 32%),\n        radial-gradient(circle at 78% 12%, rgba(84, 119, 255, 0.22), transparent 34%),\n        radial-gradient(circle at 50% 85%, rgba(84, 255, 157, 0.12), transparent 35%),\n        linear-gradient(135deg, #05070c, #08111e 48%, #05070c);\n      overflow-x: hidden;\n    }\n\n    body::before {\n      content: \"\";\n      position: fixed;\n      inset: 0;\n      pointer-events: none;\n      background-image:\n        linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px),\n        linear-gradient(90deg, rgba(255,255,255,0.035) 1px, transparent 1px);\n      background-size: 46px 46px;\n      mask-image: radial-gradient(circle at center, black, transparent 78%);\n    }\n\n    .dashboard {\n      width: min(1440px, 100%);\n      margin: 0 auto;\n      padding: 28px;\n      display: grid;\n      grid-template-columns: 1.05fr 1.4fr 1.05fr;\n      gap: 22px;\n    }\n\n    .topbar {\n      grid-column: 1 / -1;\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      padding: 18px 22px;\n      border: 1px solid var(--line);\n      border-radius: 28px;\n      background: rgba(7, 11, 18, 0.58);\n      backdrop-filter: var(--glass);\n      box-shadow: 0 20px 90px rgba(0,0,0,0.34), inset 0 0 42px rgba(66,232,255,0.05);\n    }\n\n    .brand {\n      display: flex;\n      align-items: center;\n      gap: 14px;\n      font-weight: 800;\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n    }\n\n    .logo {\n      width: 44px;\n      height: 44px;\n      display: grid;\n      place-items: center;\n      border-radius: 15px;\n      background: linear-gradient(135deg, rgba(66,232,255,0.32), rgba(84,119,255,0.15));\n      border: 1px solid rgba(66,232,255,0.42);\n      color: var(--cyan);\n      box-shadow: 0 0 28px rgba(66,232,255,0.22);\n    }\n\n    .status-row {\n      display: flex;\n      gap: 18px;\n      color: var(--muted);\n      font-size: 14px;\n      align-items: center;\n    }\n\n    .pill {\n      padding: 8px 12px;\n      border: 1px solid var(--line);\n      border-radius: 999px;\n      background: rgba(255,255,255,0.04);\n    }\n\n    .card {\n      position: relative;\n      overflow: hidden;\n      border: 1px solid var(--line);\n      border-radius: 30px;\n      background: var(--panel);\n      backdrop-filter: var(--glass);\n      box-shadow: 0 18px 60px rgba(0,0,0,0.35), inset 0 0 55px rgba(255,255,255,0.03);\n    }\n\n    .card::after {\n      content: \"\";\n      position: absolute;\n      inset: 0;\n      background: linear-gradient(135deg, rgba(255,255,255,0.09), transparent 38%);\n      pointer-events: none;\n    }\n\n    .card-content { position: relative; z-index: 1; padding: 22px; }\n\n    .card-title {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      margin-bottom: 18px;\n      color: var(--muted);\n      font-size: 13px;\n      text-transform: uppercase;\n      letter-spacing: 0.16em;\n    }\n\n    .hero {\n      min-height: 585px;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: space-between;\n      padding: 20px;\n    }\n\n    .speed-wrap {\n      width: min(430px, 100%);\n      aspect-ratio: 1;\n      position: relative;\n      display: grid;\n      place-items: center;\n    }\n\n    .speed-ring {\n      position: absolute;\n      inset: 0;\n      border-radius: 50%;\n      background:\n        conic-gradient(from 225deg, var(--cyan) 0deg, var(--blue) 155deg, rgba(255,255,255,0.08) 156deg 270deg, transparent 271deg 360deg);\n      filter: drop-shadow(0 0 24px rgba(66,232,255,0.35));\n      animation: pulse 3s infinite ease-in-out;\n    }\n\n    .speed-ring::before {\n      content: \"\";\n      position: absolute;\n      inset: 18px;\n      border-radius: 50%;\n      background: #08111e;\n      box-shadow: inset 0 0 60px rgba(66,232,255,0.08);\n    }\n\n    .speed-ring::after {\n      content: \"\";\n      position: absolute;\n      inset: 38px;\n      border: 1px dashed rgba(255,255,255,0.16);\n      border-radius: 50%;\n      animation: spin 18s linear infinite;\n    }\n\n    .speed-value {\n      position: relative;\n      z-index: 2;\n      text-align: center;\n    }\n\n    .speed-value .num {\n      font-size: clamp(82px, 11vw, 150px);\n      font-weight: 900;\n      line-height: 0.88;\n      letter-spacing: -0.08em;\n      text-shadow: 0 0 36px rgba(66,232,255,0.34);\n    }\n\n    .speed-value .unit { color: var(--muted); letter-spacing: 0.25em; font-size: 16px; }\n\n    .drive-mode {\n      display: flex;\n      gap: 10px;\n      justify-content: center;\n      margin-top: 20px;\n    }\n\n    .mode {\n      padding: 9px 15px;\n      border-radius: 999px;\n      border: 1px solid rgba(255,255,255,0.12);\n      color: var(--muted);\n      background: rgba(255,255,255,0.04);\n    }\n\n    .mode.active {\n      color: #061016;\n      background: linear-gradient(135deg, var(--cyan), var(--green));\n      box-shadow: 0 0 24px rgba(66,232,255,0.35);\n      font-weight: 800;\n    }\n\n    .car-area {\n      width: 100%;\n      min-height: 180px;\n      position: relative;\n      display: grid;\n      place-items: center;\n    }\n\n    .road {\n      position: absolute;\n      width: 86%;\n      height: 120px;\n      bottom: 12px;\n      border-radius: 50%;\n      background: radial-gradient(ellipse at center, rgba(66,232,255,0.18), transparent 65%);\n      border-bottom: 1px solid rgba(66,232,255,0.3);\n    }\n\n    .car {\n      width: 330px;\n      max-width: 85%;\n      filter: drop-shadow(0 24px 28px rgba(0,0,0,0.5));\n      animation: float 4s ease-in-out infinite;\n    }\n\n    .headlight { animation: glow 1.8s ease-in-out infinite alternate; }\n\n    .metrics {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 14px;\n      width: 100%;\n    }\n\n    .metric {\n      padding: 16px;\n      border-radius: 22px;\n      background: rgba(255,255,255,0.045);\n      border: 1px solid rgba(255,255,255,0.1);\n    }\n\n    .metric .label { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: .12em; }\n    .metric .value { margin-top: 8px; font-size: 26px; font-weight: 800; }\n    .metric small { color: var(--muted); font-size: 13px; }\n\n    .gauge {\n      margin-top: 8px;\n      height: 10px;\n      border-radius: 999px;\n      background: rgba(255,255,255,0.08);\n      overflow: hidden;\n    }\n\n    .gauge span {\n      display: block;\n      height: 100%;\n      border-radius: inherit;\n      background: linear-gradient(90deg, var(--green), var(--cyan), var(--blue));\n      box-shadow: 0 0 18px rgba(66,232,255,0.45);\n    }\n\n    .side-stack { display: grid; gap: 22px; }\n\n    .battery-big {\n      display: flex;\n      align-items: end;\n      justify-content: space-between;\n      gap: 16px;\n    }\n\n    .battery-percent { font-size: 66px; font-weight: 900; letter-spacing: -0.07em; }\n    .battery-percent span { font-size: 24px; letter-spacing: 0; color: var(--muted); }\n\n    .battery-pack {\n      height: 88px;\n      flex: 1;\n      min-width: 130px;\n      border: 2px solid rgba(84,255,157,0.46);\n      border-radius: 18px;\n      padding: 8px;\n      position: relative;\n      box-shadow: inset 0 0 25px rgba(84,255,157,0.1), 0 0 25px rgba(84,255,157,0.08);\n    }\n\n    .battery-pack::after {\n      content: \"\";\n      position: absolute;\n      right: -13px;\n      top: 32px;\n      width: 9px;\n      height: 26px;\n      border-radius: 0 6px 6px 0;\n      background: rgba(84,255,157,0.5);\n    }\n\n    .battery-fill {\n      width: 78%;\n      height: 100%;\n      border-radius: 12px;\n      background: linear-gradient(90deg, var(--green), var(--cyan));\n      animation: chargeWave 2.5s infinite ease-in-out;\n    }\n\n    .map {\n      height: 230px;\n      border-radius: 24px;\n      background:\n        linear-gradient(100deg, transparent 38%, rgba(66,232,255,0.22) 39% 41%, transparent 42%),\n        linear-gradient(24deg, transparent 47%, rgba(255,255,255,0.12) 48% 51%, transparent 52%),\n        linear-gradient(152deg, transparent 42%, rgba(84,119,255,0.25) 43% 46%, transparent 47%),\n        radial-gradient(circle at 72% 32%, var(--cyan) 0 5px, transparent 6px),\n        radial-gradient(circle at 28% 75%, var(--green) 0 5px, transparent 6px),\n        #0a1524;\n      border: 1px solid rgba(255,255,255,0.1);\n      position: relative;\n      overflow: hidden;\n    }\n\n    .route-dot {\n      position: absolute;\n      width: 16px;\n      height: 16px;\n      border-radius: 50%;\n      background: var(--cyan);\n      left: 50%;\n      top: 50%;\n      box-shadow: 0 0 0 12px rgba(66,232,255,0.12), 0 0 28px rgba(66,232,255,0.8);\n      animation: drive 7s infinite linear;\n    }\n\n    .route-info {\n      position: absolute;\n      left: 14px;\n      right: 14px;\n      bottom: 14px;\n      padding: 14px;\n      border-radius: 18px;\n      background: rgba(5,10,18,0.78);\n      border: 1px solid rgba(255,255,255,0.1);\n      backdrop-filter: blur(12px);\n      display: flex;\n      justify-content: space-between;\n      gap: 12px;\n    }\n\n    .list { display: grid; gap: 12px; }\n\n    .row {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      gap: 12px;\n      padding: 13px 0;\n      border-bottom: 1px solid rgba(255,255,255,0.08);\n    }\n    .row:last-child { border-bottom: none; }\n\n    .row strong { font-size: 18px; }\n    .row span { color: var(--muted); font-size: 13px; }\n\n    .icon-chip {\n      width: 42px;\n      height: 42px;\n      border-radius: 15px;\n      display: grid;\n      place-items: center;\n      background: rgba(66,232,255,0.1);\n      border: 1px solid rgba(66,232,255,0.22);\n      color: var(--cyan);\n    }\n\n    .climate-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 12px;\n    }\n\n    .climate-box {\n      border-radius: 20px;\n      padding: 18px;\n      background: rgba(255,255,255,0.045);\n      border: 1px solid rgba(255,255,255,0.1);\n      text-align: center;\n    }\n\n    .climate-box .temp { font-size: 38px; font-weight: 900; }\n    .climate-box .label { color: var(--muted); font-size: 12px; letter-spacing: .12em; text-transform: uppercase; }\n\n    .power-flow {\n      height: 180px;\n      position: relative;\n      border-radius: 24px;\n      background: radial-gradient(circle at center, rgba(66,232,255,0.13), transparent 58%), rgba(255,255,255,0.035);\n      border: 1px solid rgba(255,255,255,0.1);\n      overflow: hidden;\n    }\n\n    .node {\n      position: absolute;\n      width: 72px;\n      height: 72px;\n      display: grid;\n      place-items: center;\n      border-radius: 24px;\n      background: #091523;\n      border: 1px solid rgba(66,232,255,0.26);\n      box-shadow: 0 0 28px rgba(66,232,255,0.12);\n      font-size: 26px;\n    }\n\n    .node.bat { left: 24px; top: 54px; }\n    .node.motor { right: 24px; top: 54px; }\n    .node.wheel { left: 50%; transform: translateX(-50%); bottom: 18px; }\n\n    .flow-line {\n      position: absolute;\n      height: 3px;\n      background: linear-gradient(90deg, transparent, var(--cyan), transparent);\n      box-shadow: 0 0 14px rgba(66,232,255,0.8);\n      animation: flow 1.4s linear infinite;\n    }\n\n    .flow-line.one { left: 96px; right: 96px; top: 88px; }\n    .flow-line.two { width: 150px; left: calc(50% - 75px); top: 125px; transform: rotate(90deg); }\n\n    .bottom-wide { grid-column: 1 / -1; }\n\n    .telemetry {\n      display: grid;\n      grid-template-columns: repeat(5, 1fr);\n      gap: 14px;\n    }\n\n    .telemetry .metric { min-height: 92px; }\n\n    @keyframes pulse { 50% { filter: drop-shadow(0 0 38px rgba(66,232,255,0.58)); } }\n    @keyframes spin { to { transform: rotate(360deg); } }\n    @keyframes float { 50% { transform: translateY(-8px); } }\n    @keyframes glow { from { opacity: .55; } to { opacity: 1; } }\n    @keyframes chargeWave { 50% { filter: brightness(1.22); } }\n    @keyframes drive {\n      0% { left: 25%; top: 72%; }\n      35% { left: 52%; top: 47%; }\n      70% { left: 74%; top: 30%; }\n      100% { left: 25%; top: 72%; }\n    }\n    @keyframes flow {\n      from { background-position: 0 0; opacity: .35; }\n      50% { opacity: 1; }\n      to { background-position: 180px 0; opacity: .35; }\n    }\n\n    @media (max-width: 1100px) {\n      .dashboard { grid-template-columns: 1fr; }\n      .hero { min-height: auto; }\n      .topbar, .status-row { flex-wrap: wrap; }\n      .telemetry { grid-template-columns: repeat(2, 1fr); }\n    }\n\n    @media (max-width: 620px) {\n      .dashboard { padding: 14px; gap: 14px; }\n      .metrics, .telemetry, .climate-grid { grid-template-columns: 1fr; }\n      .status-row { gap: 8px; }\n      .battery-big { align-items: start; flex-direction: column; }\n      .battery-pack { width: 92%; }\n    }\n  </style>\n</head>\n<body>\n  <main class=\"dashboard\">\n    <section class=\"topbar\">\n      <div class=\"brand\">\n        <div class=\"logo\">⚡</div>\n        <div>\n          <div>Voltair X9</div>\n          <small style=\"color: var(--muted); letter-spacing: .08em;\">Electric Performance Vehicle</small>\n        </div>\n      </div>\n      <div class=\"status-row\">\n        <div class=\"pill\">09:42</div>\n        <div class=\"pill\">28°C Outside</div>\n        <div class=\"pill\">5G Connected</div>\n        <div class=\"pill\">Autopilot Ready</div>\n      </div>\n    </section>\n\n    <aside class=\"side-stack\">\n      <section class=\"card\">\n        <div class=\"card-content\">\n          <div class=\"card-title\">Battery System <span>Healthy</span></div>\n          <div class=\"battery-big\">\n            <div class=\"battery-percent\">78<span>%</span></div>\n            <div class=\"battery-pack\"><div class=\"battery-fill\"></div></div>\n          </div>\n          <div class=\"metrics\" style=\"margin-top: 18px; grid-template-columns: 1fr 1fr;\">\n            <div class=\"metric\"><div class=\"label\">Range</div><div class=\"value\">412 <small>km</small></div></div>\n            <div class=\"metric\"><div class=\"label\">Charging</div><div class=\"value\">92 <small>kW</small></div></div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"card\">\n        <div class=\"card-content\">\n          <div class=\"card-title\">Navigation <span>Active route</span></div>\n          <div class=\"map\">\n            <div class=\"route-dot\"></div>\n            <div class=\"route-info\">\n              <div><strong>Central Station</strong><br><span style=\"color:var(--muted)\">18 min • 12.4 km</span></div>\n              <div style=\"color:var(--green); font-weight:800\">ETA 10:00</div>\n            </div>\n          </div>\n        </div>\n      </section>\n    </aside>\n\n    <section class=\"card hero\">\n      <div class=\"speed-wrap\">\n        <div class=\"speed-ring\"></div>\n        <div class=\"speed-value\">\n          <div class=\"num\" id=\"speed\">86</div>\n          <div class=\"unit\">KM/H</div>\n          <div class=\"drive-mode\">\n            <div class=\"mode\">ECO</div>\n            <div class=\"mode active\">SPORT</div>\n            <div class=\"mode\">AUTO</div>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"car-area\">\n        <div class=\"road\"></div>\n        <svg class=\"car\" viewBox=\"0 0 640 260\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <path d=\"M102 154C128 101 173 73 238 70H373C433 70 481 100 520 158L585 174C604 179 617 196 617 215V219C617 230 608 239 597 239H542C536 211 512 190 482 190C452 190 427 211 422 239H220C214 211 190 190 160 190C130 190 105 211 100 239H54C40 239 29 228 29 214V198C29 180 43 165 61 163L102 154Z\" fill=\"url(#body)\" stroke=\"rgba(234,247,255,.5)\" stroke-width=\"2\"/>\n          <path d=\"M220 93H365C414 94 448 116 476 153H167C179 121 196 100 220 93Z\" fill=\"rgba(111,231,255,.16)\" stroke=\"rgba(111,231,255,.5)\" stroke-width=\"2\"/>\n          <path d=\"M242 93L221 153M367 94L390 153\" stroke=\"rgba(111,231,255,.32)\" stroke-width=\"2\"/>\n          <circle cx=\"160\" cy=\"239\" r=\"42\" fill=\"#05070c\" stroke=\"rgba(66,232,255,.55)\" stroke-width=\"8\"/>\n          <circle cx=\"482\" cy=\"239\" r=\"42\" fill=\"#05070c\" stroke=\"rgba(66,232,255,.55)\" stroke-width=\"8\"/>\n          <circle cx=\"160\" cy=\"239\" r=\"16\" fill=\"rgba(66,232,255,.7)\"/>\n          <circle cx=\"482\" cy=\"239\" r=\"16\" fill=\"rgba(66,232,255,.7)\"/>\n          <path class=\"headlight\" d=\"M526 168L603 185\" stroke=\"#42e8ff\" stroke-width=\"8\" stroke-linecap=\"round\"/>\n          <path class=\"headlight\" d=\"M88 169L41 183\" stroke=\"#ff5f7e\" stroke-width=\"7\" stroke-linecap=\"round\"/>\n          <defs>\n            <linearGradient id=\"body\" x1=\"29\" y1=\"70\" x2=\"617\" y2=\"239\" gradientUnits=\"userSpaceOnUse\">\n              <stop stop-color=\"#14243a\"/>\n              <stop offset=\"0.45\" stop-color=\"#233b62\"/>\n              <stop offset=\"1\" stop-color=\"#08111e\"/>\n            </linearGradient>\n          </defs>\n        </svg>\n      </div>\n\n      <div class=\"metrics\">\n        <div class=\"metric\"><div class=\"label\">Torque</div><div class=\"value\">620 <small>Nm</small></div><div class=\"gauge\"><span style=\"width:72%\"></span></div></div>\n        <div class=\"metric\"><div class=\"label\">Power</div><div class=\"value\">188 <small>kW</small></div><div class=\"gauge\"><span style=\"width:64%\"></span></div></div>\n        <div class=\"metric\"><div class=\"label\">Regen</div><div class=\"value\">32 <small>kW</small></div><div class=\"gauge\"><span style=\"width:38%\"></span></div></div>\n      </div>\n    </section>\n\n    <aside class=\"side-stack\">\n      <section class=\"card\">\n        <div class=\"card-content\">\n          <div class=\"card-title\">Power Flow <span>Live</span></div>\n          <div class=\"power-flow\">\n            <div class=\"flow-line one\"></div>\n            <div class=\"flow-line two\"></div>\n            <div class=\"node bat\">🔋</div>\n            <div class=\"node motor\">⚙️</div>\n            <div class=\"node wheel\">🛞</div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"card\">\n        <div class=\"card-content\">\n          <div class=\"card-title\">Cabin Climate <span>Auto</span></div>\n          <div class=\"climate-grid\">\n            <div class=\"climate-box\"><div class=\"temp\">22°</div><div class=\"label\">Driver</div></div>\n            <div class=\"climate-box\"><div class=\"temp\">23°</div><div class=\"label\">Passenger</div></div>\n          </div>\n        </div>\n      </section>\n\n      <section class=\"card\">\n        <div class=\"card-content\">\n          <div class=\"card-title\">Vehicle Status <span>All clear</span></div>\n          <div class=\"list\">\n            <div class=\"row\"><div><strong>ADAS</strong><br><span>Lane assist and adaptive cruise ready</span></div><div class=\"icon-chip\">✓</div></div>\n            <div class=\"row\"><div><strong>Tires</strong><br><span>Front 36 PSI • Rear 37 PSI</span></div><div class=\"icon-chip\">◉</div></div>\n            <div class=\"row\"><div><strong>Thermal</strong><br><span>Battery temperature optimal</span></div><div class=\"icon-chip\">❄</div></div>\n          </div>\n        </div>\n      </section>\n    </aside>\n\n    <section class=\"card bottom-wide\">\n      <div class=\"card-content\">\n        <div class=\"card-title\">Real-Time Telemetry <span>Updated now</span></div>\n        <div class=\"telemetry\">\n          <div class=\"metric\"><div class=\"label\">Odometer</div><div class=\"value\">18,420 <small>km</small></div></div>\n          <div class=\"metric\"><div class=\"label\">Efficiency</div><div class=\"value\">14.8 <small>kWh/100km</small></div></div>\n          <div class=\"metric\"><div class=\"label\">Battery Temp</div><div class=\"value\">31 <small>°C</small></div></div>\n          <div class=\"metric\"><div class=\"label\">Motor RPM</div><div class=\"value\" id=\"rpm\">6,820</div></div>\n          <div class=\"metric\"><div class=\"label\">CO₂ Saved</div><div class=\"value\">2.8 <small>t</small></div></div>\n        </div>\n      </div>\n    </section>\n  </main>\n\n  <script>\n    const speed = document.getElementById('speed');\n    const rpm = document.getElementById('rpm');\n    let t = 0;\n    setInterval(() => {\n      t += 0.08;\n      const v = Math.round(84 + Math.sin(t) * 6 + Math.sin(t * 0.37) * 3);\n      speed.textContent = v;\n      rpm.textContent = Math.round(6400 + v * 8 + Math.sin(t * 1.8) * 220).toLocaleString();\n    }, 240);\n  </script>\n</body>\n</html>"
    }
  ]
}
