{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/webview/*"],
      "@vehicle-jolt/*": [
        "src/webview/simulations/vehicle-physics/physics/jolt/*"
      ],
      "@vehicle-engine": [
        "src/webview/simulations/vehicle-physics/physics/VehicleSimulationEngine.ts"
      ],
      "@vehicle-host": [
        "src/webview/simulations/vehicle-physics/physics/VehiclePhysicsHost.ts"
      ]
    }
  },
  "include": [
    "src/webview",
    "src/window-vscode.d.ts",
    "src/assetLayout.ts",
    "src/serialport-bridge/protocol.ts",
    "src/bitstream2"
  ],
  "exclude": ["src/webview/bitstream-app", "src/bitstream"]
}
