{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/webview/*"],
      "@ternion/t3d/vscode-webview": [
        "node_modules/@ternion/t3d/dist/T3D/vscode-webview/index.d.ts"
      ],
      "@ternion/t3d/ui": ["node_modules/@ternion/t3d/dist/T3D/ui/index.d.ts"],
      "@ternion/t3d/mqtt-client": [
        "node_modules/@ternion/t3d/dist/T3D/mqtt-client/index.d.ts"
      ]
    }
  },
  "include": [
    "src/webview",
    "src/window-vscode.d.ts",
    "src/assetLayout.ts",
    "src/serialport-bridge/protocol.ts",
    "src/bitstream2"
  ],
  "exclude": ["src/webview/bitstream-app", "src/bitstream"]
}
