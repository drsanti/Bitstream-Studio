{
  "compilerOptions": {
    "module": "node16",
    "target": "ES2020",
    "outDir": "out",
    "lib": ["ES2020", "DOM"],
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/webview/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/webview/main.tsx.bk", "src/webview/main.tsx.bk2"],
  "exclude": [
    "node_modules",
    ".vscode-test",
    "**/*.test.ts",
    "vite.config.ts",
    "src/webview",
    "src/bitstream"
  ]
}
