{
  "name": "bitstream-studio",
  "displayName": "Bitstream Studio",
  "description": "Bitstream Studio — Sensor Telemetry and Sensor Studio (BS2)",
  "version": "0.1.0",
  "publisher": "TERNIONDEV",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/drsanti/Bitstream-Studio.git"
  },
  "homepage": "https://github.com/drsanti/Bitstream-Studio#readme",
  "bugs": {
    "url": "https://github.com/drsanti/Bitstream-Studio/issues"
  },
  "keywords": [
    "bitstream",
    "sensor",
    "telemetry",
    "bs2",
    "iot",
    "ternion",
    "mcu"
  ],
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "bitstream-studio.open",
        "title": "Open Bitstream Studio",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.pickApplication",
        "title": "Bitstream Studio: Choose Application",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.openBitstream",
        "title": "Open Bitstream Studio (Sensor Telemetry tab)",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.openBitstreamSensorStudio",
        "title": "Open Bitstream Studio (Sensor Studio tab)",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.configBaseUrl",
        "title": "Configure Base URL",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.reloadWebview",
        "title": "Reload Bitstream Studio Panel",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.reloadWindow",
        "title": "Reload VSCode Window",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.toggleDevTools",
        "title": "Toggle Developer Tools",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.startMqttBroker",
        "title": "Start MQTT Broker",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.stopMqttBroker",
        "title": "Stop MQTT Broker",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.startSerialBridge",
        "title": "Start Serial Bridge",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.stopSerialBridge",
        "title": "Stop Serial Bridge",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.startAllBackendServices",
        "title": "Start All Backend Services",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.stopAllBackendServices",
        "title": "Stop All Backend Services",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.startBitstreamSimulator",
        "title": "Start Bitstream Simulator",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.stopBitstreamSimulator",
        "title": "Stop Bitstream Simulator",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.openToolsPanel",
        "title": "Open Tools Panel",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.openInBrowser",
        "title": "Open in Browser (Dev Server)",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.setBrowserAppPort",
        "title": "Set Local Web App Port (Browser)",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.diagnoseFreePackStorage",
        "title": "Diagnose Free Pack on Disk",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.syncFreePackStorage",
        "title": "Sync Free Pack to Disk",
        "category": "Bitstream Studio"
      },
      {
        "command": "bitstream-studio.toggleQuickAction",
        "title": "Bitstream Studio: Toggle Quick Actions",
        "category": "Bitstream Studio"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "bitstream-studio.open",
          "when": "true"
        },
        {
          "command": "bitstream-studio.openBitstream",
          "when": "true"
        },
        {
          "command": "bitstream-studio.openBitstreamSensorStudio",
          "when": "true"
        },
        {
          "command": "bitstream-studio.startAllBackendServices",
          "when": "true"
        },
        {
          "command": "bitstream-studio.stopAllBackendServices",
          "when": "true"
        },
        {
          "command": "bitstream-studio.startBitstreamSimulator",
          "when": "true"
        },
        {
          "command": "bitstream-studio.stopBitstreamSimulator",
          "when": "true"
        },
        {
          "command": "bitstream-studio.diagnoseFreePackStorage",
          "when": "true"
        },
        {
          "command": "bitstream-studio.syncFreePackStorage",
          "when": "true"
        }
      ]
    },
    "keybindings": [
      {
        "command": "-editor.action.commentLine",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "webviewFocus"
      },
      {
        "command": "bitstream-studio.toggleQuickAction",
        "key": "ctrl+/",
        "mac": "cmd+/",
        "when": "webviewFocus"
      }
    ],
    "configuration": [
      {
        "title": "Bitstream Studio: WebSocket",
        "properties": {
          "ternion.ws.brokerPort": {
            "type": "number",
            "default": 9998,
            "minimum": 1,
            "maximum": 65535,
            "description": "TCP port for the Bitstream / serial WebSocket broker (combined bridge serial side).",
            "scope": "application"
          },
          "ternion.ws.modelBrokerPort": {
            "type": "number",
            "default": 9999,
            "minimum": 1,
            "maximum": 65535,
            "description": "TCP port for the Model Loader, Free Loader, and catalog WebSocket broker (separate from serial to avoid contention).",
            "scope": "application"
          },
          "ternion.ws.aiBrokerPort": {
            "type": "number",
            "default": 9987,
            "minimum": 1,
            "maximum": 65535,
            "description": "TCP port for the AI bridge WebSocket server (LLM + MCP bitstream tools).",
            "scope": "application"
          }
        }
      },
      {
        "title": "Bitstream Studio: Browser",
        "properties": {
          "ternion.browserApp.port": {
            "type": "number",
            "default": 0,
            "minimum": 0,
            "maximum": 65535,
            "description": "TCP port for the local static server used by \"Open in Browser\". Use 0 for an ephemeral (OS-assigned) port.",
            "scope": "application"
          }
        }
      },
      {
        "title": "Bitstream Studio: MQTT",
        "properties": {
          "ternion.mqtt.configuration": {
            "type": "object",
            "default": null,
            "description": "MQTT client configuration including connection profiles, UI state, and publish history",
            "scope": "application"
          }
        }
      },
      {
        "title": "Bitstream Studio: Assets",
        "properties": {
          "ternion.githubToken": {
            "type": "string",
            "default": "",
            "description": "GitHub personal access token (read-only repo scope is enough) for Free Loader list/sync. Raises GitHub API rate limits vs anonymous requests. If empty, GITHUB_TOKEN from the environment is used.",
            "scope": "application"
          },
          "ternion.assets.sourceStrategy": {
            "type": "string",
            "enum": [
              "local-only",
              "local-first",
              "online-only"
            ],
            "default": "local-first",
            "description": "Asset source policy for model/cubemap URLs in webview/browser mode: local-only, local-first, or online-only.",
            "scope": "application"
          }
        }
      }
    ]
  },
  "scripts": {
    "dev:clean": "node scripts/dev-clean.mjs",
    "dev:supervisor": "node scripts/dev-supervisor.mjs",
    "prestart": "npm run dev:clean",
    "start": "node scripts/start-supervised.mjs",
    "start:inner": "concurrently --prefix-colors \"cyan,blue,magenta\" --prefix \"name\" --names \"bridge,dev,ai\" --kill-others-on-fail false \"npm run start:bridge\" \"npm run dev:all\" \"npm run ai:bridge:no-serial\"",
    "start:inner:bitstream-ai": "concurrently --prefix-colors \"cyan,blue,magenta\" --prefix \"name\" --names \"bridge,dev,ai\" --kill-others-on-fail false \"npm run start:bridge\" \"npm run dev:all\" \"npm run ai:bridge\"",
    "start:with-bitstream-mcp": "npm run prestart && npm run start:inner:bitstream-ai",
    "start:inner:no-ai": "concurrently --prefix-colors \"cyan,blue\" --prefix \"name\" --names \"bridge,dev\" --kill-others-on-fail false \"npm run start:bridge\" \"npm run dev:all\"",
    "start:no-clean": "npm run start:inner",
    "dev:all": "concurrently --prefix-colors \"blue,green\" --prefix \"name\" --names \"watch,webview\" --kill-others-on-fail false --group \"npm run watch:all\" \"npm run dev:webview\"",
    "dev": "npm run dev:all",
    "start:bridge": "npx tsx src/combined-bridge-entry.ts",
    "start:bridge:watch": "npx tsx watch --clear-screen=false src/combined-bridge-entry.ts",
    "start:bridge:attach": "npx tsx src/run.bridge.ts",
    "start:model-downloader-bridge": "concurrently --prefix-colors \"cyan,magenta\" --prefix \"name\" --names \"ws-server,model-bridge\" --kill-others-on-fail true \"npx tsx src/websocket/run.ws.server.ts --port=9999\" \"npx tsx src/model-downloader/run.model-downloader.bridge.ts\"",
    "run:model-downloader-bridge": "npx tsx src/model-downloader/run.model-downloader.bridge.ts",
    "run:model-downloader-client": "npx tsx src/model-downloader/run.model-downloader.client.ts",
    "mqtt:broker:start": "npx tsx src/mqtt-node/run-mqtt-broker.ts",
    "mqtt:broker:status": "npx tsx src/mqtt-node/broker-control-cli.ts status",
    "mqtt:broker:stop": "npx tsx src/mqtt-node/broker-control-cli.ts stop",
    "mqtt:broker:restart": "npx tsx src/mqtt-node/broker-control-cli.ts restart",
    "bitstream:mcp:stdio": "npx tsx src/bitstream/mcp-server/run.mcp-server.ts",
    "bitstream:mcp:stdio:attach": "npx tsx src/bitstream/mcp-server/run.mcp-server.ts --path=COM5 --baudRate=921600",
    "bitstream:mcp:validate": "npx tsx src/bitstream/mcp-server/validate-descriptors.ts",
    "bitstream:mcp:smoke": "npx tsx src/bitstream/mcp-server/mcp-e2e-smoke.ts",
    "bitstream:mcp:gate": "npm run -s bitstream:mcp:validate && npm run -s test:bitstream2 && npm run -s bitstream:mcp:smoke",
    "ai:bridge": "npx tsx src/ai/run.ai.bridge.ts",
    "ai:bridge:no-serial": "npx tsx src/ai/run.ai.bridge.ts --no-bitstream",
    "bitstream:assistant": "npx tsx src/ai/run.ai.bridge.ts",
    "dev:model-loader-browser": "concurrently --prefix-colors \"cyan,blue\" --prefix \"name\" --names \"model-bridge,browser\" --kill-others-on-fail false \"npm run start:model-downloader-bridge\" \"npm run dev:webview\"",
    "dev:with-model-loader": "concurrently --prefix-colors \"cyan,blue,green\" --prefix \"name\" --names \"model-bridge,dev\" --kill-others-on-fail false \"npm run start:model-downloader-bridge\" \"npm run dev\"",
    "vscode:prepublish": "npm run compile",
    "compile": "node scripts/build-extension.js && npm run build:webview",
    "watch": "node scripts/build-extension.js --watch",
    "watch:all": "concurrently --prefix-colors \"yellow,cyan\" --prefix \"name\" --names \"extension,webview\" --kill-others-on-fail false --hide \"exited\" \"node scripts/build-extension.js --watch\" \"vite build --watch\"",
    "copy:jolt-assets": "node scripts/copy-jolt-assets.mjs",
    "prebuild:webview": "npm run copy:jolt-assets",
    "postinstall": "node scripts/copy-jolt-assets.mjs",
    "build:webview": "vite build",
    "dev:webview": "vite",
    "rebuild:full": "npm run compile && npm run package",
    "package": "npm run compile && npx vsce package --no-dependencies --allow-missing-repository",
    "publish": "npm run compile && npx vsce publish --no-dependencies --allow-missing-repository",
    "version:patch": "npm version patch",
    "version:minor": "npm version minor",
    "version:major": "npm version major",
    "release:patch": "npm run version:patch && npm run publish",
    "release:minor": "npm run version:minor && npm run publish",
    "release:major": "npm run version:major && npm run publish",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "lint:glass-button-guard": "node scripts/check-no-legacy-glass-imports.js",
    "test": "node ./out/test/runTest.js",
    "rebuild": "npx @electron/rebuild -v 37.3.1",
    "test:mqtt:wss": "npx tsx src/mqtt-node/test-mqtt-wss.ts",
    "test:bitstream": "npm run test:bitstream2",
    "test:bitstream2": "npx tsx --test --test-force-exit tests/bitstream2/*.test.ts",
    "bitstream2:mock-probe": "npx tsx src/bitstream2/dev/run-mock-probe.ts",
    "bitstream2:dev-inject": "npx tsx src/bitstream2/dev/run-ws-injector.ts",
    "bitstream2:sim-scenario": "npx tsx src/bitstream2/dev/run-sim-scenario.ts",
    "bitstream2:uart-probe": "npx tsx src/bitstream2/dev/run-uart-probe.ts",
    "bitstream2:uart-sensor-rate-check": "npx tsx src/bitstream2/dev/run-uart-sensor-rate-check.ts",
    "bitstream2:uart-matrix": "npx tsx src/bitstream2/dev/run-uart-sensor-matrix.ts",
    "bitstream2:uart-matrix:smoke": "npx tsx src/bitstream2/dev/run-uart-sensor-matrix.ts --tier=smoke",
    "bitstream2:uart-matrix:standard": "npx tsx src/bitstream2/dev/run-uart-sensor-matrix.ts --tier=standard",
    "bitstream2:uart-cfg-roundtrip": "npx tsx src/bitstream2/dev/run-uart-sensor-cfg-roundtrip.ts",
    "bitstream2:uart-cfg-behavior": "npx tsx src/bitstream2/dev/run-uart-sensor-cfg-behavior.ts",
    "check:free-pack-storage": "npx tsx src/asset-sync/dev/check-free-pack-globalstorage.ts",
    "sync:free-pack-storage": "npx tsx src/asset-sync/dev/sync-free-pack-to-globalstorage.ts",
    "bitstream2:golden:gen": "npx tsx src/bitstream2/dev/generate-golden-fixtures.ts",
    "bitstream:serial:probe": "npx tsx src/bitstream/probe-serial-list.ts",
    "bitstream:serial:open-close": "npx tsx src/bitstream/probe-serial-open-close.ts",
    "bitstream:probe:protocol": "npx tsx src/bitstream/probe-protocol-torture-cli.ts",
    "bitstream:ci:check": "npm run test:bitstream2 && npm run bitstream:sync:check",
    "bitstream:sync:check": "node scripts/check-streamsight-bitstream-sync.js",
    "bitstream:sync:update": "node scripts/check-streamsight-bitstream-sync.js --update",
    "verify:ai-mcp-tools": "npx tsx src/ai/bridge/verify-ai-mcp-tools.ts",
    "publish:studio-asset-manifest": "node scripts/publish-studio-asset-manifest.mjs",
    "sync:studio-manifest-models": "node scripts/sync-studio-manifest-models.mjs",
    "sync:studio-manifest-textures": "node scripts/sync-studio-manifest-textures.mjs",
    "sync:studio-cubemap-assets": "node scripts/sync-studio-cubemap-assets.mjs"
  },
  "description:scripts": {
    "start": "Dev supervisor (127.0.0.1:9910) + full stack: start:bridge, dev:all, ai:bridge:no-serial, model-downloader bridge. Runs prestart/dev:clean first.",
    "start:no-clean": "Same inner stack as npm start without supervisor wrapper (start:inner).",
    "start:with-bitstream-mcp": "prestart + start:inner:bitstream-ai — broker + dev + ai:bridge with HostSession attach for MCP tools.",
    "start:bridge": "Combined serial/bitstream WebSocket broker (:9998) + bridge. Restart manually after bridge TS edits.",
    "start:bridge:watch": "start:bridge with tsx watch — auto-restart on bridge source changes.",
    "start:bridge:attach": "Attach bridge clients to an already-running broker (avoids second listener on :9998).",
    "dev": "Alias for dev:all — extension TS watch + Vite webview. Does not start broker or model-loader WS (:9999).",
    "dev:all": "Extension watch + Vite only. Pair with start:bridge in another terminal for Sensor Telemetry / Simulator.",
    "dev:webview": "Vite dev server (opens /). Pair with start:bridge for broker-backed telemetry.",
    "dev:with-model-loader": "dev + start:model-downloader-bridge so browser Model Catalog / loader can use WS :9999.",
    "dev:model-loader-browser": "Vite + model-downloader bridge only (no extension TS watch).",
    "dev:clean": "Free dev TCP ports (default 9998, 5173; override DEV_CLEAN_PORTS). Use --dry-run to inspect only.",
    "compile": "Full build: extension host + webview (out/) for VS Code and VSIX.",
    "build:webview": "Build webview only to out/webview/.",
    "package": "compile + vsce package (.vsix).",
    "test:bitstream2": "BS2 unit tests (framing, simulator, golden parity). test:bitstream is an alias.",
    "bitstream:ci:check": "test:bitstream2 + StreamSight bitstream sync check.",
    "ai:bridge": "AI WebSocket server (:9987). Included in npm start as ai:bridge:no-serial to avoid COM contention.",
    "bitstream:assistant": "Alias for ai:bridge — see src/ai/README.md.",
    "ai:bridge:no-serial": "AI bridge without serial HostSession attach.",
    "publish:studio-asset-manifest": "Upload studio-asset-manifest.v1.json to ternion-3d-assets-free (GITHUB_TOKEN required).",
    "sync:studio-manifest-models": "Refresh studio-asset-manifest model rows from ternion-3d-assets-free assets/models/manifest.json.",
    "sync:studio-manifest-textures": "Refresh studio-asset-manifest cubemap/HDRI/image rows from assets/textures/*/manifest.json.",
    "sync:studio-cubemap-assets": "Download cubemap JPEGs from ternion-3d-assets-free into src/assets/textures/cubemap/.",
    "check:free-pack-storage": "List free-pack files under Cursor/VS Code globalStorage (diagnostic CLI).",
    "sync:free-pack-storage": "Download ternion-3d-assets-free into globalStorage assets/free (same as Free Loader sync)."
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.16",
    "@types/chroma-js": "^3.1.2",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/serialport": "^8.0.5",
    "@types/three": "^0.180.0",
    "@types/vscode": "^1.75.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.4.1",
    "@typescript-eslint/parser": "^6.4.1",
    "@vitejs/plugin-react": "^5.1.0",
    "@vscode/vsce": "^3.6.2",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "latest",
    "baseline-browser-mapping": "^2.8.32",
    "concurrently": "^9.2.1",
    "esbuild": "^0.25.11",
    "eslint": "^8.47.0",
    "kill-port": "^2.0.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vite": "^7.1.10",
    "vite-plugin-static-copy": "^3.1.4"
  },
  "dependencies": {
    "@dimforge/rapier3d": "^0.19.2",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slider": "^1.2.2",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/rapier": "^2.2.0",
    "@serialport/parser-byte-length": "^13.0.0",
    "@serialport/parser-delimiter": "^13.0.0",
    "@serialport/parser-readline": "^13.0.0",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.10.2",
    "aedes": "^0.51.3",
    "chroma-js": "^3.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "gsap": "^3.13.0",
    "jolt-physics": "^0.38.1",
    "lucide-react": "^0.546.0",
    "mqtt": "^5.14.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "react-toastify": "^11.0.5",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "serialport": "^13.0.0",
    "tailwind-merge": "^3.3.1",
    "three": "^0.180.0",
    "three-nebula": "^10.0.3",
    "uuid": "^13.0.0",
    "websocket-stream": "^5.3.0",
    "ws": "^8.18.3",
    "zod": "^4.4.1",
    "zustand": "^5.0.0"
  }
}
