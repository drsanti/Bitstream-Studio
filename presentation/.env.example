# Copy to .env.local and customize as needed

# T3D WebSocket broker URL (default: localhost)
# Change if the broker runs on a different host (e.g. remote device)
VITE_WS_URL=ws://127.0.0.1:9998

# Simulation fallback FPS when WS is disconnected
VITE_SIM_FPS=60

# Sensor hook update rate for reactive UI (Hz) — lower = less React re-renders
VITE_UI_FPS=30
